---
import PageLayout from "@/layouts/Base.astro";
import SocialList from "@/components/SocialList.astro";
import friends from "@/data/friendLinks.json";
import { t } from "@/utils/i18n";
export const prerender = true;

const locale = "en";

const meta = {
	description: t(locale, "about", "description"),
	title: t(locale, "about", "title"),
};

// Scatter slots; add more coordinates if friends.length > slots.length
const slots: [number, number][] = [
	[12, 22], [78, 12], [28, 48], [88, 58], [8, 78], [52, 85], [65, 38],
];
function seeded(name: string, n: number) {
	const s = name.split("").reduce((a, c) => a + c.charCodeAt(0), 0);
	return ((s * 31 + n * 7) % 100) / 100;
}
const linksOnDrawing = friends.map((f, i) => {
	const r = (n: number) => seeded(f.name, n);
	const idx = i % slots.length;
	const [baseLeft, baseTop] = slots[idx];
	return {
		...f,
		left: baseLeft + (r(1) - 0.5) * 6,
		top: baseTop + (r(2) - 0.5) * 6,
		rot: -28 + r(3) * 56,
	};
});
---
<PageLayout meta={meta}>
	<article>
		<header class="mb-8">
			<div class="mb-8 flex items-center gap-4">
				<span class="ornate-divider flex-1"></span>
				<span class="font-display text-sm font-medium uppercase tracking-[0.25em] text-accent engraved">
					{t(locale, "about", "title")}
				</span>
				<span class="ornate-divider flex-1"></span>
			</div>
			<p class="font-body text-lg font-normal leading-relaxed text-textColor">
				Everything, be it poetry, music, film, or fiction, is connected to imagination. This is a slice of my imagination—observations about life and reflections on the world, all cut into thin pieces by words...
			</p>
		</header>

		<section aria-label="Friend Links" class="mb-8">
			<div class="mb-8 flex items-center gap-4">
				<span class="ornate-divider flex-1"></span>
				<span class="font-display text-sm font-medium uppercase tracking-[0.25em] text-accent engraved">
					{t(locale, "about", "friendLinks")}
				</span>
				<span class="ornate-divider flex-1"></span>
			</div>
			<figure class="about-drawing-figure my-8">
				<div class="about-drawing-wrap">
					<img
						src="/images/about-drawing.png"
						alt=""
						class="about-drawing-img"
						width="900"
						height="600"
						loading="lazy"
						fetchpriority="low"
					/>
					<div class="about-drawing-links">
						{
							linksOnDrawing.map(({ name, link, left, top, rot }) => (
								<a
									href={link}
									target="_blank"
									rel="noopener noreferrer"
									class="about-drawing-link font-display"
									style={`left: ${left}%; top: ${top}%; transform: translate(-50%, -50%) rotate(${rot}deg);`}
								>
									{name}
								</a>
							))
						}
					</div>
				</div>
			</figure>
		</section>

		<section aria-label="Connect">
			<div class="mb-8 flex items-center gap-4">
				<span class="ornate-divider flex-1"></span>
				<span class="font-display text-sm font-medium uppercase tracking-[0.25em] text-accent engraved">
					{t(locale, "about", "connect")}
				</span>
				<span class="ornate-divider flex-1"></span>
			</div>
			<div class="about-connect inline-flex rounded-md bg-[var(--academia-ornate-bg)]/50 px-3 py-2.5">
				<SocialList mode="social" />
			</div>
		</section>
	</article>
	<style>
		.about-connect :global(svg) {
			width: 1.75rem;
			height: 1.75rem;
		}
		.about-connect :global(li) {
			width: 2.25rem;
			height: 2.25rem;
		}

		.about-drawing-figure {
			margin-left: auto;
			margin-right: auto;
			width: 100%;
			max-width: min(900px, 100%);
		}
		.about-drawing-wrap {
			position: relative;
			width: 100%;
			aspect-ratio: 3 / 2;
			overflow: hidden;
		}
		.about-drawing-img {
			position: absolute;
			left: 50%;
			top: 50%;
			width: 100%;
			height: 100%;
			object-fit: contain;
			transform: translate(-50%, -50%) rotate(90deg);
			transform-origin: center;
			opacity: 0.92;
			mix-blend-mode: multiply;
		}
		/* Dark mode drawing blend: see global.css */
		.about-drawing-links {
			position: absolute;
			inset: 0;
			pointer-events: none;
		}
		.about-drawing-link {
			pointer-events: auto;
			position: absolute;
			transform-origin: center;
			white-space: nowrap;
			font-size: clamp(0.7rem, 2.2vw, 0.9rem);
			font-weight: 500;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: hsl(var(--theme-accent));
			text-decoration: none;
			transition: color 0.2s ease;
		}
		.about-drawing-link:hover {
			color: hsl(var(--theme-accent-2));
		}
	</style>
</PageLayout>
